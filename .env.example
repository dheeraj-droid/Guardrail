GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_APP_ID=0
# GITHUB_APP_PRIVATE_KEY MUST be PKCS#8 (begins "-----BEGIN PRIVATE KEY-----").
# GitHub downloads keys in PKCS#1 ("-----BEGIN RSA PRIVATE KEY-----"); octokit v4's Web
# Crypto JWT signer rejects those at runtime with `DataError: Invalid keyData`. Convert once:
#   openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in app.pem -out app.pkcs8.pem
# Store it \n-escaped on one line (env.ts un-escapes \n back to real newlines).
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n"
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SCAN_CONCURRENCY=8
MAX_SCAN_FILES=2000

# --- Public onboarding dashboard (optional; only needed if you enable it — see
# docs/DEPLOY.md Step 6). The webhook pipeline above works without any of these set. ---
# Client ID/secret from the GitHub App settings page (requires the App to be Public).
GITHUB_APP_CLIENT_ID=replace-me
GITHUB_APP_CLIENT_SECRET=replace-me
# The App's URL slug, e.g. "guardrail-yourname" from https://github.com/apps/guardrail-yourname
GITHUB_APP_SLUG=replace-me
# >= 32 chars; symmetric key material for the session cookie (AES-256-GCM). Generate with:
#   openssl rand -hex 32
GUARDRAIL_SESSION_SECRET=replace-me-with-a-random-string-at-least-32-characters-long
# Public base URL of this deployment, no trailing slash, e.g. https://guardrail-xyz.vercel.app
APP_BASE_URL=https://YOUR-DEPLOYMENT.example.com
